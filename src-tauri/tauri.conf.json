{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lightmark",
  "version": "0.1.1",
  "identifier": "app.lightmark",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Lightmark",
        "width": 1440,
        "height": 960,
        "minWidth": 1040,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNEMEY1MUUyNkUwNjdCMTYKUldRV2V3WnU0bEVQUFVFaFFsNkhNWks0eHRpYTdjbnNqbkZaaExXcklnMWpGWHkyZkt6RU9pYnkK",
      "endpoints": [
        "https://github.com/reiserFSs/Lightmark/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
